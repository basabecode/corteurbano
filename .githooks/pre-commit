#!/usr/bin/env bash
# .githooks/pre-commit
# Detecta credenciales hardcodeadas antes de permitir un commit.
#
# Se activa automáticamente al ejecutar `pnpm install` (via "prepare" en package.json).
# Para omitir en casos excepcionales: git commit --no-verify

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# Archivos staged relevantes (excluye lock files, binarios, snapshots)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
  | grep -E '\.(ts|tsx|js|mjs|cjs|json|sh|env|yml|yaml)$' \
  | grep -v 'package-lock\.json' \
  | grep -v 'pnpm-lock\.yaml' \
  | grep -v '\.snap$' \
  || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FOUND=false

# Patrones de credenciales hardcodeadas (detecta asignaciones con valores literales)
# Se busca en las líneas AÑADIDAS del diff (prefijo "+")
PATTERNS=(
  "password\s*=\s*['\"][^'\"]{6,}['\"]"
  "PASSWORD\s*=\s*['\"][^'\"]{6,}['\"]"
  "contraseña\s*=\s*['\"][^'\"]{6,}['\"]"
  "secret\s*=\s*['\"][^'\"]{8,}['\"]"
  "SECRET\s*=\s*['\"][^'\"]{8,}['\"]"
  "api_key\s*=\s*['\"][^'\"]{8,}['\"]"
  "API_KEY\s*=\s*['\"][^'\"]{8,}['\"]"
  "access_token\s*=\s*['\"][^'\"]{10,}['\"]"
  "private_key\s*=\s*['\"][^'\"]{10,}['\"]"
)

# Valores falsos que no deben bloquearse (placeholders, ejemplos)
ALLOWLIST_PATTERN="(process\.env|your[-_]|example|placeholder|changeme|tu-clave|xxx|<.*>|\.\.\.)"

for FILE in $STAGED_FILES; do
  for PATTERN in "${PATTERNS[@]}"; do
    # Extrae líneas añadidas que coincidan con el patrón
    MATCHES=$(git diff --cached -- "$FILE" 2>/dev/null \
      | grep -E "^\+[^+]" \
      | grep -iE "$PATTERN" \
      | grep -ivE "$ALLOWLIST_PATTERN" \
      || true)

    if [ -n "$MATCHES" ]; then
      echo -e "${RED}⛔ Posible credencial detectada en: ${CYAN}$FILE${NC}"
      echo "$MATCHES" | head -3 | sed 's/^/   /'
      FOUND=true
    fi
  done
done

if [ "$FOUND" = true ]; then
  echo ""
  echo -e "${RED}⛔ Commit bloqueado por credenciales hardcodeadas.${NC}"
  echo -e "${YELLOW}   Usa variables de entorno (.env.local) en lugar de valores literales.${NC}"
  echo "   Documentación: https://nextjs.org/docs/app/building-your-application/configuring/environment-variables"
  echo ""
  echo "   Para omitir esta verificación (úsalo con responsabilidad):"
  echo "   git commit --no-verify"
  exit 1
fi

exit 0
