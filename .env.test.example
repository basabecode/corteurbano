# Test Environment Variables
# Copia este archivo a .env.test.local y completa con tus credenciales reales.
# .env.test.local está en .gitignore — NUNCA subas credenciales reales al repo.
#
# Uso del script de setup barbero:
#   TEST_BARBER_PASSWORD=tuClaveSegura node scripts/setup-barber-test.mjs
# O define la variable en .env.test.local y ejecuta el script directamente.

# Test Supabase Configuration
TEST_SUPABASE_URL=https://your-test-project.supabase.co
TEST_SUPABASE_ANON_KEY=your-test-anon-key
TEST_SUPABASE_SERVICE_KEY=your-test-service-role-key

# Cuenta de prueba del barbero
# Script de setup: scripts/setup-barber-test.mjs
TEST_BARBER_EMAIL=barbero@test.com
TEST_BARBER_PASSWORD=pon-aqui-tu-contraseña-segura

# Test Telegram Configuration
TEST_TELEGRAM_BOT_TOKEN=test-bot-token
TEST_TELEGRAM_ADMIN_CHAT_ID=123456789

# Playwright Configuration
PLAYWRIGHT_BASE_URL=http://localhost:3000
